# MetroPrints Hermes Agent Environment Variables
#
# Production (VPS):   /etc/hermes/hermes.env   (chmod 600)
# Local (macOS):      inject via launchd plist EnvironmentVariables
#                     or source before running cron scripts

# DeepSeek API (required — all agents use this for LLM reasoning)
DEEPSEEK_API_KEY=sk-...

# Slack (required — Socket Mode and Web API)
SLACK_XAPP_TOKEN=xapp-...      # Socket Mode app-level token (starts with xapp-)
SLACK_XOXB_TOKEN=xoxb-...      # Bot User OAuth token (starts with xoxb-)
SLACK_BOT_USER_ID=U...         # Bot user ID from Slack

# Notion (required — database access)
NOTION_API_KEY=ntn_...         # Notion integration token (starts with ntn_)

# Email (optional — Gmail IMAP for FBI Email #2 monitoring)
# Generate App Password at: https://myaccount.google.com/apppasswords
METROPRINTS_EMAIL=shah@metroprints.co
METROPRINTS_EMAIL_PASS=...     # Gmail App Password (16 chars, no spaces)

# Token Rotation (optional — for xoxe token refresh)
SLACK_CLIENT_ID=...            # Slack App client ID for OAuth
SLACK_CLIENT_SECRET=...        # Slack App client secret for OAuth
